{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strictPropertyInitialization": false

  },
  "include": ["src/**/*"], // Garanta que sua lógica está dentro de /src
  "exclude": ["node_modules", "**/*.spec.ts"]
}


